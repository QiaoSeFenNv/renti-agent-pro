# =============================================================================
# 服务器部署用 .env —— 上传到服务器 /opt/renti/.env
# 复制本文件为 .env 并填好真实值，不要提交到 git。
# 路径与 docker-compose.prod.yml 中引用的变量一一对应。
# =============================================================================

# --- 镜像 tag（Jenkinsfile 部署阶段会自动覆盖为本次构建的 commit tag）---
IMAGE_TAG=latest

# --- PostgreSQL（compose 里 ${POSTGRES_PASSWORD} 注入到 db 与 backend 两个服务）---
POSTGRES_PASSWORD=请改成强随机密码

# --- 内部 token：backend <-> agent-service 互调用时校验 ---
RENTI_INTERNAL_TOKEN=请改成强随机token

# --- DeepSeek LLM ---
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-pro
LLM_TIMEOUT_SECONDS=60
TOOL_TIMEOUT_SECONDS=20

# --- 高德 ---
AMAP_WEB_SERVICE_KEY=你的高德webservice key

# --- Qdrant ---
QDRANT_URL=https://your-cluster.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-jwt
QDRANT_COLLECTION=renti_listings_v2

# --- Jina ---
JINA_URL=https://api.jina.ai/v1/embeddings
JINA_API_KEY=jina_xxx
JINA_MODEL=ina-embeddings-v3

# --- Neo4j ---
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=xxx
NEO4J_DATABASE=neo4j
NEO4J_PROXY_URL=
NEO4J_INSECURE_SKIP_VERIFY=true
